# Frontend Environment Variables
# These are consumed at BUILD TIME by Vite. Set them when building for production.

# Base URL of the backend API.
# Leave empty if frontend and backend share the same origin (nginx proxies /api/).
# Set to your backend domain if they are separate, e.g.:
#   VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=

# WebSocket URL for generation progress updates.
# Optional — if omitted, it is auto-derived from VITE_API_BASE_URL:
#   https://  → wss://
#   http://   → ws://
#   empty     → same host/protocol as the page
# VITE_WS_URL=wss://api.yourdomain.com
